# Server
NODE_ENV=development
PORT=5001
API_PREFIX=/api

# Database - SQLite (file-based, no server needed!)
DATABASE_URL=file:./dev.db

# Redis (optional - not required for basic functionality)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=local-dev-jwt-secret-key-8a9f2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=local-dev-refresh-secret-key-1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f
JWT_REFRESH_EXPIRES_IN=7d

# Email (not required for testing)
EMAIL_FROM=noreply@yourcompany.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ML Service (will use rule-based fallback)
ML_SERVICE_URL=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# AWS S3 (if using S3 for file storage)
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Google Calendar & Sheets Integration
# Get service account key from Google Cloud Console (see GOOGLE_INTEGRATION_SETUP.md)
# IMPORTANT: Never commit real credentials to git!
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_TRACKING_SHEET_ID=
